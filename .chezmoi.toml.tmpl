{{- $should_install_opencode := promptBoolOnce . "should_install_opencode" "Install OpenCode?" false -}}
{{- $git_name := promptStringOnce . "git_name" "Git username?" -}}
{{- $git_email := promptStringOnce . "git_email" "Git email?" -}}

[data]
    should_install_opencode = {{ $should_install_opencode }}
    git_name = {{ $git_name | quote }}
    git_email = {{ $git_email | quote }}
