#!/bin/bash
# pinentry-keychain: returns YubiKey PIN from macOS Keychain

echo "OK Pleased to meet you, pinentry-keychain"

while IFS= read -r line; do
    case "${line%% *}" in
        GETPIN)
            printf 'D '
            security find-generic-password -s "yubikey-pin" -w 2>/dev/null
            printf 'OK\n'
            ;;
        BYE)
            echo "OK"
            exit 0
            ;;
        *)
            echo "OK"
            ;;
    esac
done
