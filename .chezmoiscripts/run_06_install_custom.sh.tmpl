{{ if and (eq .chezmoi.os "darwin") .should_install_remctl -}}
#!/bin/bash
set -euo pipefail

echo "=== Custom installs ==="

if command -v remctl &>/dev/null; then
    echo "remctl already installed. Skipping."
else
    echo "Installing remctl..."
    clone_dir=$(mktemp -d)
    git clone https://github.com/viticci/remctl.git "$clone_dir/remctl"
    pushd "$clone_dir/remctl"
    ./install.sh --bootstrap

    if [ -f SKILL.md ]; then
        mkdir -p "$HOME/.agents/skills/remctl"
        mv SKILL.md "$HOME/.agents/skills/remctl/SKILL.md"
    fi

    popd
    rm -rf "$clone_dir"

    echo ""
    echo "  → Manually run 'remctl onboard' to complete installation."
    echo ""
fi

if command -v rustup &>/dev/null; then
    echo "rustup already installed. Skipping."
else
    echo "Installing Rust toolchain via rustup..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
fi

btt_preset="{{ .chezmoi.sourceDir }}/.chezmoiscripts/assets/Default.bttpreset"
if [ -f "$btt_preset" ] && pgrep -x "BetterTouchTool" &>/dev/null; then
    echo "Importing BetterTouchTool preset..."
    osascript -e "tell application \"BetterTouchTool\" to import_preset \"$btt_preset\"" > /dev/null
elif [ -f "$btt_preset" ]; then
    echo "BetterTouchTool not running. Skipping preset import."
else
    echo "BTT preset file not found. Skipping."
fi

echo "Done."
{{ end -}}
