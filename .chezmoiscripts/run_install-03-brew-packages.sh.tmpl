{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail
export HOMEBREW_NO_AUTO_UPDATE=1

eval "$(/opt/homebrew/bin/brew shellenv)"

echo "=== Brew packages ==="

if ! brew list --formula bun &>/dev/null; then
    brew install bun
fi

if ! brew list --formula playwright-cli &>/dev/null; then
    brew install playwright-cli
fi

if ! brew tap | grep -qxF jundot/omlx &>/dev/null; then
    brew tap jundot/omlx
fi
if ! brew list --formula omlx &>/dev/null; then
    brew install omlx
fi

if ! brew list --formula hf &>/dev/null; then
    brew install hf
fi

if ! brew list --formula zsh-autosuggestions &>/dev/null; then
    brew install zsh-autosuggestions
fi

if ! brew list --formula fnm &>/dev/null; then
    brew install fnm
fi

if ! brew list --formula uv &>/dev/null; then
    brew install uv
fi

{{ if (default false .install_opencode) -}}
if ! brew list --formula opencode &>/dev/null; then
    brew install opencode
fi
{{ end -}}

echo "Done."
{{ end -}}
