[user]
	name = {{ .git_name }}
	email = {{ .git_email }}

[core]
	fsmonitor = true

[alias]
    // switch branch with fzf
	b = "!f() { command -v fzf &>/dev/null || { echo 'fzf not installed' >&2; return 1; }; git for-each-ref --format='%(refname:short)' refs/heads/ | fzf +s +m -e | xargs -r git switch; }; f"
    l = log --oneline --graph --decorate --first-parent

[push]
	autoSetupRemote = true
