typeset -U path

[[ -d "$HOME/bin" ]] && path=("$HOME/bin" $path)
[[ -d "$HOME/.local/bin" ]] && path=("$HOME/.local/bin" $path)

export PATH

# GPG agent for YubiKey commit signing + SSH auth
export SSH_AUTH_SOCK=$HOME/.gnupg/S.gpg-agent.ssh

# Pretty ls colors
export LSCOLORS='GxFxCxExBxGxFxBxBxCxEx'

# Local override, not tracked in Chezmoi / Git
if [ -f $HOME/.zshenv_override ]; then
    source "$HOME/.zshenv_override"
fi
