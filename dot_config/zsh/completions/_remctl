            _arguments                 '--via-eventkit[Limited read-only EventKit fallback; no numeric ids or private metadata]'                 '(-v --verbose)'{-v,--verbose}'[Verbose output]'                 '--json[JSON output]'
            return
            ;;
        templates)
            _arguments                 '--json[JSON output]'
            return
            ;;
        template-info)
            _arguments                 '--template-id[Read by numeric template ID]:id:'                 '--json[JSON output]'
