        today)
            _arguments                 '--no-overdue[Exclude overdue reminders]'                 '--via-eventkit[Limited read-only EventKit fallback; no numeric ids or private metadata]'                 '(-v --verbose)'{-v,--verbose}'[Verbose output]'                 '--json[JSON output]'
            return
            ;;
