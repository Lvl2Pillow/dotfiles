            _arguments                 '--list-id[Show list by stable numeric ID]:id:'                 '--completed[Include completed reminders]'                 '--via-eventkit[Limited read-only EventKit fallback; no numeric ids or private metadata]'                 '(-v --verbose)'{-v,--verbose}'[Verbose output]'                 '--json[JSON output]'
            return
            ;;
        search)
            _arguments                 '--completed[Include completed reminders]'                 '--via-eventkit[Limited read-only EventKit fallback; no numeric ids or private metadata]'                 '(-v --verbose)'{-v,--verbose}'[Verbose output]'                 '--json[JSON output]'
            return
